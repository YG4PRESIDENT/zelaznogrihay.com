---
import Sidequests from '../components/Sidequests.astro';
import SiteNav from '../components/SiteNav.astro';

interface Props {
    title: string;
    description?: string;
    showSidebar?: boolean;
    fullWidth?: boolean;
    compactHeader?: boolean;
}

const {
    title,
    description = 'The writings, work, and mind map of Yahir Gonzalez.',
    showSidebar = true,
    fullWidth = false,
    compactHeader = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/png" href="/favicon.png" />
        <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon.png" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <div class:list={['main-container', { 'without-sidebar': !showSidebar, 'full-width-page': fullWidth, 'compact-header': compactHeader }]}>
            <header id="main-header">
                <div class="header-container">
                    <a href="/home" class="logo-link" aria-label="Go home">
                        <img src="/images/full-logo-new.png" alt="Ship Logo" class="logo-image" />
                    </a>
                </div>
                <SiteNav />
            </header>

            <div class="content-container">
                {showSidebar && (
                    <aside class="sidebar">
                        <button id="sidebar-toggle" class="sidebar-toggle" aria-label="Toggle Life Quests" aria-expanded="true">
                            <span class="toggle-icon">◀</span>
                        </button>
                        <div class="sidebar-content">
                            <Sidequests />
                        </div>
                    </aside>
                )}

                <main class:list={{ 'full-width': fullWidth }}>
                    <slot />
                </main>
            </div>
        </div>
    </body>
</html>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        if (localStorage.getItem('authenticated') !== 'true') {
            window.location.href = '/';
            return;
        }

        const sidebarToggle = document.getElementById('sidebar-toggle');
        const sidebar = document.querySelector<HTMLElement>('.sidebar');
        const mainContainer = document.querySelector<HTMLElement>('.main-container');

        if (!sidebarToggle || !sidebar || !mainContainer) return;

        const updateToggle = () => {
            const collapsed = sidebar.classList.contains('collapsed');
            const mobile = window.innerWidth < 768;
            sidebarToggle.innerHTML = mobile
                ? (collapsed ? '&#9650;' : '&#9660;')
                : (collapsed ? '&#9654;' : '&#9664;');
            sidebarToggle.setAttribute('aria-expanded', String(!collapsed));
        };

        const applyStoredState = () => {
            const mobile = window.innerWidth < 768;
            const key = mobile ? 'sidebarCollapsedMobile' : 'sidebarCollapsedDesktop';
            const stored = localStorage.getItem(key);
            const collapsed = stored === null ? mobile : stored === 'true';

            sidebar.classList.toggle('mobile', mobile);
            sidebar.classList.toggle('collapsed', collapsed);
            mainContainer.classList.toggle('sidebar-collapsed', collapsed);
            document.body.style.overflow = mobile && !collapsed ? 'hidden' : '';
            updateToggle();
        };

        sidebarToggle.addEventListener('click', () => {
            const mobile = window.innerWidth < 768;
            sidebar.classList.toggle('collapsed');
            const collapsed = sidebar.classList.contains('collapsed');
            mainContainer.classList.toggle('sidebar-collapsed', collapsed);
            localStorage.setItem(mobile ? 'sidebarCollapsedMobile' : 'sidebarCollapsedDesktop', String(collapsed));
            document.body.style.overflow = mobile && !collapsed ? 'hidden' : '';
            updateToggle();
        });

        applyStoredState();
        window.addEventListener('resize', applyStoredState);
    });
</script>

<style is:global>
    :root {
        --bg-color: #0a0a0a;
        --panel-color: #101210;
        --text-color: #f5f5f0;
        --muted-text: rgba(245, 245, 240, 0.62);
        --accent-color: #d4af37;
        --accent-dark: #8b4513;
        --accent-light: rgba(212, 175, 55, 0.2);
        --terminal-green: #39ff14;
        --terminal-green-soft: rgba(57, 255, 20, 0.16);
        --sidebar-width: 250px;
        --sidebar-collapsed-width: 50px;
    }

    * {
        box-sizing: border-box;
    }

    html {
        min-height: 100%;
        font-family: 'Courier New', Courier, monospace;
        background: var(--bg-color);
        color: var(--text-color);
        font-size: 16px;
    }

    body {
        min-height: 100%;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        background: var(--bg-color);
    }

    .main-container {
        display: flex;
        flex-direction: column;
        width: 100%;
        min-width: 0;
        max-width: 100vw;
        min-height: 100vh;
        padding-top: 1.1rem;
    }

    #main-header {
        width: 100%;
        min-width: 0;
        max-width: 100vw;
        padding: 0.3rem 1rem 0;
        border-bottom: 1px solid var(--accent-color);
        background: var(--bg-color);
        z-index: 10;
    }

    .header-container {
        display: flex;
        justify-content: center;
        align-items: center;
        max-width: 100%;
        overflow: hidden;
    }

    .logo-link {
        display: block;
        line-height: 0;
    }

    .logo-image {
        display: block;
        max-width: 100%;
        width: auto;
        height: auto;
        max-height: 245px;
        margin-bottom: -16px;
        transition: transform 0.25s ease;
    }

    .logo-image:hover {
        transform: scale(1.025);
    }

    .compact-header {
        padding-top: 0.35rem;
    }

    .compact-header #main-header {
        padding-top: 0;
    }

    .compact-header .logo-image {
        max-height: 150px;
        margin-bottom: -10px;
    }

    .content-container {
        display: grid;
        grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
        width: 100%;
        min-width: 0;
        flex: 1;
        min-height: 0;
        transition: grid-template-columns 0.25s ease;
    }

    .without-sidebar .content-container {
        display: block;
    }

    .sidebar {
        width: var(--sidebar-width);
        background: var(--bg-color);
        border-right: 1px solid var(--accent-color);
        position: relative;
        transition: width 0.25s ease;
    }

    .sidebar.collapsed {
        width: var(--sidebar-collapsed-width);
    }

    .sidebar-toggle {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        border: 1px solid var(--accent-color);
        background: var(--bg-color);
        color: var(--accent-color);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 40;
        box-shadow: 0 0 12px rgba(212, 175, 55, 0.35);
        font: inherit;
    }

    .sidebar-toggle:hover {
        background: var(--accent-light);
    }

    .sidebar-content {
        height: 100%;
        overflow: hidden;
        transition: opacity 0.2s ease;
    }

    .sidebar.collapsed .sidebar-content {
        opacity: 0;
        pointer-events: none;
    }

    .main-container.sidebar-collapsed .content-container {
        grid-template-columns: var(--sidebar-collapsed-width) minmax(0, 1fr);
    }

    main {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        min-height: 100%;
        padding: 1.4rem 1.5rem 3rem;
        overflow-x: hidden;
    }

    main.full-width {
        padding: 0;
        overflow: hidden;
    }

    a {
        color: var(--accent-color);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    a:hover {
        color: var(--text-color);
    }

    .page-shell {
        width: 100%;
        max-width: 980px;
        margin: 0 auto;
    }

    .page-title {
        margin: 0 0 1.4rem;
        padding-bottom: 0.55rem;
        border-bottom: 1px solid var(--accent-color);
        color: var(--text-color);
        font-size: 1.5rem;
    }

    .simple-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .simple-row {
        border-bottom: 1px dotted rgba(212, 175, 55, 0.24);
    }

    .simple-row:last-child {
        border-bottom: 0;
    }

    .simple-row > a,
    .simple-row > .row-content {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1.5rem;
        width: 100%;
        padding: 0.8rem 0.5rem;
        color: var(--text-color);
    }

    .simple-row > a:hover {
        background: rgba(212, 175, 55, 0.08);
        transform: translateX(3px);
    }

    .row-meta {
        flex: 0 0 auto;
        color: var(--muted-text);
        font-size: 0.8rem;
        font-style: italic;
    }

    @media (max-width: 767px) {
        .main-container {
            padding-top: 0.5rem;
        }

        #main-header {
            padding: 0.2rem 0.5rem 0;
        }

        .logo-image {
            max-height: 155px;
            margin-bottom: -10px;
        }

        .compact-header .logo-image {
            max-height: 105px;
            margin-bottom: -7px;
        }

        .content-container {
            display: flex;
            flex-direction: column;
        }

        .sidebar {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            height: auto;
            max-height: 70vh;
            border-right: 0;
            border-top: 1px solid var(--accent-color);
            z-index: 30;
            transform: translateY(0);
            background: var(--bg-color);
            box-shadow: 0 -5px 15px rgba(0, 0, 0, 0.55);
            transition: transform 0.25s ease;
        }

        .sidebar.mobile.collapsed {
            width: 100%;
            transform: translateY(calc(100% - 40px));
        }

        .sidebar-toggle {
            top: -20px;
            right: 20px;
            width: 42px;
            height: 42px;
            border: 2px solid var(--bg-color);
            background: var(--accent-color);
            color: var(--bg-color);
        }

        .sidebar-content {
            max-height: calc(70vh - 40px);
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }

        main {
            padding: 1.1rem 0.8rem 4rem;
        }

        main.full-width {
            padding: 0 0 2.5rem;
        }

        .page-title {
            font-size: 1.2rem;
            margin-bottom: 0.85rem;
        }

        .simple-row > a,
        .simple-row > .row-content {
            align-items: flex-start;
            gap: 0.75rem;
            padding-inline: 0;
        }
    }

    @media (min-width: 768px) {
        .logo-image {
            max-height: 255px;
        }

        .main-container.sidebar-collapsed main:not(.full-width) {
            padding-left: 2rem;
        }
    }
</style>
