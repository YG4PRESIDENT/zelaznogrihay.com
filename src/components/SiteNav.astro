---
const pathname = Astro.url.pathname;

const links = [
    { href: '/', label: 'Home', active: pathname === '/' || pathname === '/home' || pathname === '/home/' },
    { href: '/mind-map', label: 'Mind Map', active: pathname.startsWith('/mind-map') },
    { href: '/work', label: 'Work', active: pathname.startsWith('/work') },
];
---

<nav class="site-nav" aria-label="Primary navigation">
    <ul>
        {links.map(link => (
            <li>
                <a href={link.href} class:list={{ active: link.active }} aria-current={link.active ? 'page' : undefined}>
                    {link.label}
                </a>
            </li>
        ))}
    </ul>
</nav>

<style>
    .site-nav {
        width: 100%;
        min-width: 0;
        max-width: 100vw;
        overflow-x: auto;
        scrollbar-width: none;
        border-top: 1px solid rgba(57, 255, 20, 0.18);
        border-bottom: 1px solid var(--accent-color);
        background: var(--bg-color);
        z-index: 50;
    }

    .site-nav::-webkit-scrollbar {
        display: none;
    }

    ul {
        display: flex;
        align-items: center;
        justify-content: center;
        width: max-content;
        min-width: 100%;
        list-style: none;
        margin: 0;
        padding: 0.8rem 1rem 0.75rem;
        box-sizing: border-box;
    }

    li {
        display: flex;
        align-items: center;
        white-space: nowrap;
    }

    li:not(:last-child)::after {
        content: '·';
        color: rgba(57, 255, 20, 0.45);
        margin: 0 0.75rem;
    }

    a {
        color: rgba(57, 255, 20, 0.7);
        font-size: 0.94rem;
        letter-spacing: 0.03em;
        padding-bottom: 0.2rem;
        border-bottom: 1px solid transparent;
        text-decoration: none;
    }

    a:hover,
    a.active {
        color: var(--terminal-green);
        border-bottom-color: var(--terminal-green);
        text-shadow: 0 0 8px rgba(57, 255, 20, 0.45);
    }

    @media (max-width: 767px), (max-height: 520px) and (max-width: 950px) {
        .site-nav {
            position: sticky;
            top: 0;
            height: var(--mobile-nav-height);
            overflow: hidden;
        }

        ul {
            justify-content: center;
            width: 100%;
            min-width: 0;
            height: 100%;
            padding: 0 1rem;
        }

        li:not(:last-child)::after {
            margin-inline: 0.6rem;
        }

        a {
            display: flex;
            align-items: center;
            min-height: 44px;
            font-size: 0.82rem;
        }
    }
</style>
