---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';

const posts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 5);
---

<MainLayout
    title="zelaznogrihay.com - Home"
    description="The latest writings from Yahir Gonzalez."
>
    <section class="home-page">
        <h1>Writings</h1>
        <ul>
            {posts.map(post => (
                <li>
                    <a href={`/blog/${post.id.replace(/\.(md|mdx)$/i, '')}/`}>
                        <span>{post.data.title}</span>
                        <time datetime={post.data.pubDate.toISOString()}>
                            {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                                year: 'numeric',
                                month: 'short',
                                day: 'numeric',
                                timeZone: 'America/Chicago',
                            })}
                        </time>
                    </a>
                </li>
            ))}
        </ul>
        <a class="archive-link" href="/writings">All writings →</a>
    </section>
</MainLayout>

<style>
    .home-page {
        width: min(100%, 920px);
        margin: 0 auto;
        padding: 0.25rem 0 3rem;
    }

    h1 {
        margin: 0 0 0.7rem;
        padding-bottom: 0.55rem;
        border-bottom: 1px solid var(--accent-color);
        color: var(--text-color);
        font-size: 1.45rem;
    }

    ul {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    li {
        border-bottom: 1px dotted rgba(212, 175, 55, 0.24);
    }

    li:last-child {
        border-bottom: 0;
    }

    li a {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1.5rem;
        width: 100%;
        padding: 0.85rem 0.65rem;
        box-sizing: border-box;
        color: var(--text-color);
    }

    li a:hover {
        background: rgba(212, 175, 55, 0.08);
        transform: translateX(3px);
    }

    li span {
        font-weight: 700;
        line-height: 1.45;
    }

    time {
        flex: 0 0 auto;
        color: var(--muted-text);
        font-size: 0.78rem;
        font-style: italic;
    }

    .archive-link {
        display: inline-block;
        margin-top: 1.1rem;
        color: var(--terminal-green);
        font-size: 0.8rem;
    }

    @media (max-width: 767px) {
        .home-page {
            padding-top: 0;
        }

        h1 {
            font-size: 1.2rem;
        }

        li a {
            align-items: flex-start;
            flex-direction: column;
            gap: 0.25rem;
            padding-inline: 0;
        }
    }
</style>
