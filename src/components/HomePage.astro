---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import Sidequests from './Sidequests.astro';

const posts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 5);
---

<MainLayout
    title="zelaznogrihay.com - Home"
    description="The latest writings from Yahir Gonzalez."
>
    <section class="home-page">
        <h1>Writings</h1>
        <ul>
            {posts.map(post => (
                <li>
                    <a href={`/blog/${post.id.replace(/\.(md|mdx)$/i, '')}/`}>
                        <span>{post.data.title}</span>
                        <time datetime={post.data.pubDate.toISOString()}>
                            {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                                year: 'numeric',
                                month: 'short',
                                day: 'numeric',
                                timeZone: 'America/Chicago',
                            })}
                        </time>
                    </a>
                </li>
            ))}
        </ul>
        <a class="archive-link" href="/writings">All writings →</a>

        <details class="mobile-quests">
            <summary>Life Quests &amp; Voyages</summary>
            <Sidequests compact={true} />
        </details>
    </section>
</MainLayout>

<style>
    .home-page {
        width: min(100%, 920px);
        margin: 0 auto;
        padding: 0.25rem 0 3rem;
    }

    h1 {
        margin: 0 0 0.7rem;
        padding-bottom: 0.55rem;
        border-bottom: 1px solid var(--accent-color);
        color: var(--text-color);
        font-size: 1.45rem;
    }

    ul {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    li {
        border-bottom: 1px dotted rgba(212, 175, 55, 0.24);
    }

    li:last-child {
        border-bottom: 0;
    }

    li a {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1.5rem;
        width: 100%;
        padding: 0.85rem 0.65rem;
        box-sizing: border-box;
        color: var(--text-color);
    }

    li a:hover {
        background: rgba(212, 175, 55, 0.08);
        transform: translateX(3px);
    }

    li span {
        font-weight: 700;
        line-height: 1.45;
    }

    time {
        flex: 0 0 auto;
        color: var(--muted-text);
        font-size: 0.78rem;
        font-style: italic;
    }

    .archive-link {
        display: inline-block;
        margin-top: 1.1rem;
        color: var(--terminal-green);
        font-size: 0.8rem;
    }

    .mobile-quests {
        display: none;
    }

    @media (max-width: 767px), (max-height: 520px) and (max-width: 950px) {
        .home-page {
            padding-top: 0;
        }

        h1 {
            margin-bottom: 0.35rem;
            font-size: 1.12rem;
        }

        li a {
            align-items: flex-start;
            flex-direction: column;
            gap: 0.18rem;
            padding: 0.72rem 0;
        }

        li span {
            font-size: 0.94rem;
            line-height: 1.35;
        }

        time {
            font-size: 0.7rem;
        }

        .archive-link {
            min-height: 44px;
            margin-top: 0.65rem;
            padding: 0.75rem 0;
            font-size: 0.76rem;
        }

        .mobile-quests {
            display: block;
            scroll-margin-top: calc(var(--mobile-nav-height) + 0.5rem);
            margin-top: 1.15rem;
            border-top: 1px solid rgba(57, 255, 20, 0.22);
            border-bottom: 1px solid rgba(57, 255, 20, 0.22);
        }

        .mobile-quests summary {
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-height: 52px;
            color: var(--accent-color);
            font-size: 0.86rem;
            font-weight: 700;
            cursor: pointer;
            list-style: none;
        }

        .mobile-quests summary::-webkit-details-marker {
            display: none;
        }

        .mobile-quests summary::after {
            content: '+';
            color: var(--terminal-green);
            font-size: 1.1rem;
            font-weight: 400;
        }

        .mobile-quests[open] {
            padding-bottom: 1rem;
        }

        .mobile-quests[open] summary::after {
            content: '−';
        }
    }
</style>
