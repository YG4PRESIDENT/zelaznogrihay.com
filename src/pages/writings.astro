---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<MainLayout title="Writings | zelaznogrihay.com" description="Writings by Yahir Gonzalez.">
    <section class="page-shell">
        <h1 class="page-title">Writings</h1>
        <ul class="simple-list">
            {posts.map(post => (
                <li class="simple-row">
                    <a href={`/blog/${post.id.replace(/\.(md|mdx)$/i, '')}/`}>
                        <span>{post.data.title}</span>
                        <time class="row-meta" datetime={post.data.pubDate.toISOString()}>
                            {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                                year: 'numeric', month: 'short', day: 'numeric', timeZone: 'America/Chicago'
                            })}
                        </time>
                    </a>
                </li>
            ))}
        </ul>
    </section>
</MainLayout>
