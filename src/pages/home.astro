---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
    title="zelaznogrihay.com - Home"
    description="The personal website of Yahir Gonzalez."
    showSidebar={false}
>
    <section class="home-page">
        <p class="home-label">Now</p>
        <h1>Building products, writing, and connecting ideas.</h1>
        <p class="home-copy">
            This is where I keep the things I am making, the things I am thinking about,
            and the map connecting it all.
        </p>
        <p class="current-line"><span>Currently</span> Rankett, Orph, Betio, and Lift ATX.</p>
    </section>
</MainLayout>

<style>
    .home-page {
        width: min(100%, 720px);
        margin: 0 auto;
        padding: clamp(2.5rem, 8vh, 6rem) 0 4rem;
    }

    .home-label {
        margin: 0 0 1rem;
        color: var(--terminal-green);
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    h1 {
        max-width: 680px;
        margin: 0;
        color: var(--text-color);
        font-size: clamp(1.7rem, 4vw, 2.7rem);
        font-weight: 600;
        line-height: 1.22;
        letter-spacing: -0.035em;
    }

    .home-copy {
        max-width: 620px;
        margin: 1.5rem 0 0;
        color: var(--muted-text);
        font-size: 0.98rem;
        line-height: 1.75;
    }

    .current-line {
        margin: 2.4rem 0 0;
        padding-top: 1rem;
        border-top: 1px solid rgba(57, 255, 20, 0.18);
        color: var(--muted-text);
        font-size: 0.82rem;
        line-height: 1.6;
    }

    .current-line span {
        margin-right: 0.75rem;
        color: var(--terminal-green);
    }

    @media (max-width: 767px) {
        .home-page {
            padding-top: 2.2rem;
        }

        h1 {
            font-size: 1.65rem;
        }

        .home-copy {
            font-size: 0.9rem;
        }
    }
</style>
